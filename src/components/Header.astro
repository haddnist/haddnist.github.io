---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<div class="brand-group">
			<a href="/" class="brand-link">
				<span class="brand-title">{SITE_TITLE}</span>
			</a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">home</HeaderLink>
			<HeaderLink href="/diary">diary & tasks</HeaderLink>
			<HeaderLink href="/blog">blog</HeaderLink>
			<HeaderLink href="/about">about</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://github.com/haddnist" target="_blank" title="GitHub">
				<span class="sr-only">Go to GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="18" height="18" fill="currentColor">
					<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
				</svg>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 2rem;
		background: var(--bg-root);
		border-bottom: 1px solid var(--border);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1080px;
		width: 100%;
		margin: 0 auto;
		height: 3.25rem;
	}
	.brand-group {
		display: flex;
		align-items: center;
	}
	.brand-link {
		display: flex;
		align-items: center;
		text-decoration: none;
	}
	.brand-title {
		font-family: var(--font-mono);
		font-weight: 600;
		font-size: 1rem;
		color: var(--text-primary);
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 1.25rem;
	}
	.social-links {
		display: flex;
		align-items: center;
	}
	.social-links a {
		color: var(--text-muted);
		transition: color 0.1s ease;
		display: flex;
		align-items: center;
	}
	.social-links a:hover {
		color: var(--text-primary);
	}
	@media (max-width: 768px) {
		header {
			padding: 0 1rem;
		}
		.social-links {
			display: none;
		}
		.internal-links {
			gap: 0.5rem;
		}
	}
</style>
