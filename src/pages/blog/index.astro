---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog // ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.page-header {
				margin-bottom: 2.5rem;
				border-bottom: 1px solid var(--border);
				padding-bottom: 1.5rem;
			}
			.page-title {
				font-size: 2.2rem;
				font-weight: 700;
				letter-spacing: -0.035em;
				color: #fff;
				margin: 0 0 0.5rem 0;
			}
			.page-desc {
				color: var(--text-muted);
				font-size: 1rem;
				margin: 0;
			}
			.entry-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
			}
			.entry-link {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				padding: 1rem 1.25rem;
				background: var(--bg-surface);
				border: 1px solid var(--border);
				border-radius: 10px;
				text-decoration: none;
				transition: all 0.15s ease;
				gap: 1.5rem;
			}
			.entry-link:hover {
				background: var(--bg-surface-hover);
				border-color: var(--border-active);
				transform: translateX(4px);
			}
			.entry-left {
				display: flex;
				align-items: baseline;
				gap: 1.5rem;
				flex-grow: 1;
				min-width: 0;
			}
			.entry-date {
				font-family: var(--font-mono);
				font-size: 0.85rem;
				color: var(--text-dim);
				white-space: nowrap;
				flex-shrink: 0;
				width: 100px;
			}
			.entry-title {
				font-size: 1.05rem;
				font-weight: 600;
				color: var(--text-primary);
				transition: color 0.15s ease;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}
			.entry-link:hover .entry-title {
				color: #fff;
			}
			.empty-state {
				color: var(--text-dim);
				font-style: italic;
				padding: 3rem 0;
				text-align: center;
				background: var(--bg-surface);
				border: 1px dashed var(--border);
				border-radius: 10px;
			}
			@media (max-width: 720px) {
				.entry-left {
					flex-direction: column;
					gap: 0.3rem;
				}
				.entry-date {
					width: auto;
					font-size: 0.78rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<header class="page-header">
				<h1 class="page-title">Blog & Articles</h1>
				<p class="page-desc">Long-form technical writing, architectural notes, and concurrency deep-dives.</p>
			</header>
			{
				posts.length === 0 ? (
					<div class="empty-state">No blog posts published yet.</div>
				) : (
					<ul class="entry-list">
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`} class="entry-link">
									<div class="entry-left">
										<span class="entry-date"><FormattedDate date={post.data.pubDate} /></span>
										<span class="entry-title">{post.data.title}</span>
									</div>
								</a>
							</li>
						))}
					</ul>
				)
			}
		</main>
		<Footer />
	</body>
</html>
