---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.nav-list {
				list-style: none;
				padding: 0;
				margin: 1.5rem 0;
			}
			.nav-list li {
				margin-bottom: 0.75rem;
			}
			.nav-list a {
				font-weight: 600;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 style="margin-bottom: 0.5rem;">Siddhant</h1>
			<p style="color: #8b949e; margin-bottom: 2rem;">Systems programming, concurrency, and daily engineering log.</p>

			<p>
				Welcome to my public accountability website. I use this space to track my daily coursework, document low-level systems programming concepts, and maintain discipline.
			</p>

			<p>
				Currently working through:
			</p>
			<ul>
				<li><strong>KAIST CS Concurrency Course</strong> — memory models, atomics, and lock-free structures.</li>
				<li><strong>The Rust Programming Language</strong> (Brown University interactive edition) — ownership, borrowing, and lifetimes.</li>
			</ul>

			<h2 style="margin-top: 2.5rem; margin-bottom: 1rem; font-size: 1.3rem;">Sections</h2>
			<ul class="nav-list">
				<li><a href="/diary">Diary & Tasks</a> — Daily action items, evening progress reports, and sprint checklists.</li>
				<li><a href="/blog">Blog</a> — Technical articles and architectural deep dives.</li>
				<li><a href="/about">About</a> — More background about my engineering journey.</li>
			</ul>
		</main>
		<Footer />
	</body>
</html>
