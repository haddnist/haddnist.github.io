---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				margin-bottom: 3rem;
				border-bottom: 1px solid var(--border);
				padding-bottom: 1.5rem;
			}
			.hero h1 {
				font-size: 2rem;
				font-weight: 600;
				margin-bottom: 0.5rem;
				color: #fff;
			}
			.hero p {
				color: var(--text-primary);
				font-size: 1.15rem;
				max-width: 800px;
				margin: 0;
			}
			.section-title {
				font-family: var(--font-mono);
				font-size: 0.85rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				color: var(--text-dim);
				margin: 2.5rem 0 1rem 0;
				border-bottom: 1px solid var(--border);
				padding-bottom: 0.3rem;
			}
			.grid-2col {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 2rem;
			}
			.item {
				margin-bottom: 1.25rem;
			}
			.item h3 {
				font-size: 1.1rem;
				font-weight: 600;
				margin: 0 0 0.3rem 0;
				color: var(--text-primary);
			}
			.item p {
				font-size: 0.95rem;
				color: var(--text-muted);
				margin: 0;
				line-height: 1.5;
			}
			.nav-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.nav-list li {
				margin-bottom: 0.5rem;
				font-family: var(--font-mono);
				font-size: 0.95rem;
			}
			.nav-list a {
				color: var(--text-primary);
			}
			.nav-list span {
				color: var(--text-muted);
				font-family: var(--font-sans);
				margin-left: 0.5rem;
			}
			@media (max-width: 768px) {
				.grid-2col {
					grid-template-columns: 1fr;
					gap: 1.5rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<p>
					Systems programming, concurrency, and low-level software engineering. Public coursework logs and daily sprint accountability.
				</p>
			</div>

			<div class="grid-2col">
				<div>
					<div class="section-title">Current Focus</div>
					<div class="item">
						<h3>KAIST CS Concurrency Course</h3>
						<p>Hardware memory models, atomic memory ordering, and lock-free concurrent data structures.</p>
					</div>
					<div class="item">
						<h3>The Rust Programming Language</h3>
						<p>Interactive edition of the Brown Rust Book. Focus on ownership rules, borrowing, and lifetimes.</p>
					</div>
				</div>

				<div>
					<div class="section-title">Navigation</div>
					<ul class="nav-list">
						<li><a href="/diary">/diary</a> <span>Daily action items, evening progress reports, sprint checklists.</span></li>
						<li><a href="/blog">/blog</a> <span>Long-form technical writing, architectural notes, concurrency concepts.</span></li>
						<li><a href="/about">/about</a> <span>Background and engineering philosophy.</span></li>
						<li><a href="https://github.com/haddnist" target="_blank">github.com/haddnist</a> <span>Public repositories and code.</span></li>
					</ul>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
