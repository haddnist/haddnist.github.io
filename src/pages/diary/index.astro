---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const entries = (await getCollection('diary')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`diary & tasks // ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.page-header {
				margin-bottom: 2rem;
				border-bottom: 1px solid var(--border);
				padding-bottom: 1rem;
			}
			.page-title {
				font-size: 1.8rem;
				font-weight: 600;
				color: #fff;
				margin: 0 0 0.4rem 0;
			}
			.page-desc {
				color: var(--text-muted);
				font-size: 0.95rem;
				margin: 0;
			}
			.entry-table {
				width: 100%;
				border-collapse: collapse;
			}
			.entry-table tr {
				border-bottom: 1px solid var(--border);
			}
			.entry-table td {
				padding: 0.75rem 0;
				vertical-align: baseline;
			}
			.col-date {
				font-family: var(--font-mono);
				font-size: 0.88rem;
				color: var(--text-dim);
				width: 130px;
				white-space: nowrap;
			}
			.col-title {
				flex-grow: 1;
			}
			.col-title a {
				font-size: 1rem;
				font-weight: 500;
				color: var(--text-primary);
				text-decoration: none;
			}
			.col-title a:hover {
				color: var(--accent);
				text-decoration: underline;
			}
			.col-status {
				font-family: var(--font-mono);
				font-size: 0.8rem;
				color: var(--text-muted);
				text-align: right;
				white-space: nowrap;
				width: 120px;
			}
			.empty-state {
				color: var(--text-dim);
				font-style: italic;
				padding: 2rem 0;
			}
			@media (max-width: 768px) {
				.entry-table td {
					display: block;
					padding: 0.2rem 0;
					text-align: left;
				}
				.entry-table tr {
					padding: 0.75rem 0;
					display: block;
				}
				.col-date {
					width: auto;
					font-size: 0.8rem;
				}
				.col-status {
					width: auto;
					text-align: left;
					margin-top: 0.2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1 class="page-title">diary & tasks</h1>
				<p class="page-desc">Daily coursework progress, sprint accountability, and task checklists.</p>
			</div>
			{
				entries.length === 0 ? (
					<div class="empty-state">No diary entries published yet.</div>
				) : (
					<table class="entry-table">
						<tbody>
							{entries.map((entry) => (
								<tr>
									<td class="col-date"><FormattedDate date={entry.data.pubDate} /></td>
									<td class="col-title"><a href={`/diary/${entry.id}/`}>{entry.data.title}</a></td>
									<td class="col-status">{entry.data.status || ''}</td>
								</tr>
							))}
						</tbody>
					</table>
				)
			}
		</main>
		<Footer />
	</body>
</html>
