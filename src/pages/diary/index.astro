---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const entries = (await getCollection('diary')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Diary & Tasks // ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 800px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2.5em 1em;
			}
			.diary-list {
				list-style-type: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
			}
			.diary-item {
				background: #161b22;
				border: 1px solid #30363d;
				border-radius: 10px;
				padding: 1.5rem;
				transition: border-color 0.2s, transform 0.2s;
			}
			.diary-item:hover {
				border-color: var(--accent);
				transform: translateX(4px);
			}
			.diary-item a {
				text-decoration: none;
				display: block;
			}
			.entry-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 0.5rem;
				flex-wrap: wrap;
				gap: 0.5rem;
			}
			.title {
				margin: 0;
				color: #fff;
				font-size: 1.4rem;
				font-weight: 700;
			}
			.date {
				color: #8b949e;
				font-family: 'JetBrains Mono', monospace;
				font-size: 0.85rem;
			}
			.status {
				background: rgba(0, 242, 254, 0.15);
				color: var(--accent);
				padding: 0.2rem 0.6rem;
				border-radius: 50px;
				font-size: 0.8rem;
				font-weight: 600;
			}
			.desc {
				color: #8b949e;
				font-size: 0.95rem;
				margin: 0.5rem 0 0 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section style="margin-bottom: 2.5rem; border-bottom: 1px solid #30363d; padding-bottom: 1.5rem;">
				<h1 style="font-size: 2.2rem; color: #fff; margin-bottom: 0.5rem;">📋 Daily Diary & Task Tracker</h1>
				<p style="color: #8b949e; font-size: 1.05rem; margin: 0;">
					Active sprint goals, daily progress reports, and interactive checklists. This is where daily discipline and accountability live.
				</p>
			</section>

			<section>
				<ul class="diary-list">
					{
						entries.map((entry) => (
							<li class="diary-item">
								<a href={`/diary/${entry.id}/`}>
									<div class="entry-header">
										<h2 class="title">{entry.data.title}</h2>
										<div style="display: flex; gap: 0.75rem; align-items: center;">
											{entry.data.status && <span class="status">{entry.data.status}</span>}
											<span class="date"><FormattedDate date={entry.data.pubDate} /></span>
										</div>
									</div>
									{entry.data.description && <p class="desc">{entry.data.description}</p>}
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
