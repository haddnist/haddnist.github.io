---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { status?: string };

const { title, description, pubDate, updatedDate, status } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={`${title} // haddnist`} description={description || 'Engineering log'} />
		<style>
			article {
				width: 100%;
			}
			.post-header {
				margin-bottom: 2rem;
				border-bottom: 1px solid var(--border);
				padding-bottom: 1.25rem;
			}
			.meta-row {
				font-family: var(--font-mono);
				font-size: 0.85rem;
				color: var(--text-dim);
				margin-bottom: 0.5rem;
			}
			.post-title {
				font-size: 2rem;
				font-weight: 600;
				color: var(--text-primary);
				margin: 0;
			}
			.last-updated-on {
				font-style: italic;
				color: var(--text-dim);
				font-size: 0.85rem;
				margin-top: 0.5rem;
			}
			@media (max-width: 768px) {
				.post-title {
					font-size: 1.6rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<header class="post-header">
					<div class="meta-row">
						<FormattedDate date={pubDate} />
						{status && <span> [{status}]</span>}
					</div>
					<h1 class="post-title">{title}</h1>
					{
						updatedDate && (
							<div class="last-updated-on">
								Updated on <FormattedDate date={updatedDate} />
							</div>
						)
					}
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
