---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'diary'>['data'];

const { title, description, pubDate, status } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={`${title} // Diary`} description={description || ''} />
		<style>
			article {
				max-width: 680px;
				margin: 0 auto;
			}
			.diary-header {
				margin-bottom: 2.5rem;
				padding-bottom: 1.75rem;
				border-bottom: 1px solid var(--border);
			}
			.meta-row {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				margin-bottom: 0.85rem;
				font-family: var(--font-mono);
				font-size: 0.82rem;
				color: var(--text-muted);
			}
			.status-pill {
				color: var(--accent);
				background: var(--accent-glow);
				border: 1px solid rgba(56, 189, 248, 0.3);
				padding: 0.15rem 0.5rem;
				border-radius: 9999px;
				font-weight: 500;
				font-size: 0.75rem;
				letter-spacing: 0.02em;
			}
			.entry-title {
				font-family: var(--font-sans);
				font-size: 2.4rem;
				font-weight: 700;
				letter-spacing: -0.035em;
				line-height: 1.2;
				color: var(--text-primary);
				margin: 0;
			}
			.entry-desc {
				color: var(--text-dim);
				font-size: 1.05rem;
				margin-top: 0.6rem;
				line-height: 1.5;
				margin-bottom: 0;
			}
			.prose {
				color: #d1d5db;
			}
			@media (max-width: 720px) {
				.entry-title {
					font-size: 1.85rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<header class="diary-header">
					<div class="meta-row">
						<FormattedDate date={pubDate} />
						{status && <><span>•</span><span class="status-pill">{status}</span></>}
					</div>
					<h1 class="entry-title">{title}</h1>
					{description && <p class="entry-desc">{description}</p>}
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
